{
  "name": "repomap-mcp-server",
  "version": "2.1.0",
  "description": "MCP server for RepoMap \u2014 code intelligence via AST-based repository analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "repomap-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "repomap-bin": "^2.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "repomap",
    "code-analysis",
    "ast",
    "tree-sitter",
    "code-intelligence",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gjczone/repomap-mcp-server.git"
  },
  "homepage": "https://github.com/gjczone/repomap-mcp-server",
  "bugs": {
    "url": "https://github.com/gjczone/repomap-mcp-server/issues"
  },
  "license": "MIT"
}
